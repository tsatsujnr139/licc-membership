{
  "name": "@liccm/membership",
  "private": true,
  "type": "module",
  "scripts": {
    "convex": "dotenv -e .env.local -- convex dev",
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "generate-routes": "tsr generate",
    "build": "vite build && sh -c 'test -d .output/server && cp instrument.server.mjs .output/server || true'",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "ultracite check",
    "typecheck": "dotenv -e .env.local -- tsc --noEmit",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "fix": "ultracite fix",
    "bones": "boneyard-js build http://localhost:3000/admin/applications --out src/bones"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@convex-dev/react-query": "0.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "boneyard-js": "^1.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.4.0",
    "dotenv-cli": "^11.0.0",
    "google-libphonenumber": "^3.2.44",
    "libphonenumber-js": "^1.13.5",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.77.0",
    "react-phone-number-input": "^3.4.17",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.2",
    "ultracite": "7.8.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.13.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=v24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.1"
}
